{
  "uid": "popularity",
  "title": "store",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "current": { "selected": true, "text": "uat", "value": "uat" },
        "options": [
          { "selected": true, "text": "uat", "value": "uat" },
          { "selected": false, "text": "prod", "value": "prod" }
        ],
        "query": "uat,prod",
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Refresh requests (last 24h, sum)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(increase(store_snapd_request_total{action=\"refresh\",env=\"$env\"}[24h]))", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "decimals": 0
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Actions by app",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 12 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (snap, action) (increase(store_snapd_request_total{env=\"$env\",snap!=\"\"}[$__range]))", "refId": "A", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "groupingToMatrix", "options": { "columnField": "action", "rowField": "snap", "valueField": "Value", "emptyValue": "zero" } }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "sortBy": [ { "displayName": "refresh", "desc": true } ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } },
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "snap\\action" },
            "properties": [
              { "id": "displayName", "value": "snap" }
            ]
          }
        ]
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Snapd request rate (per minute, by action)",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (action) (rate(store_snapd_request_total{env=\"$env\"}[1m])) * 60", "refId": "A", "legendFormat": "{{action}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "bargauge",
      "title": "Refresh requests per arch (last 24h)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (arch) (increase(store_snapd_request_total{action=\"refresh\",env=\"$env\"}[24h]))", "refId": "A", "legendFormat": "{{arch}}", "instant": true }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlPu" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "decimals": 0
        }
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Requests per status (last 24h)",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (status) (increase(store_snapd_request_total{env=\"$env\"}[24h]))", "refId": "A", "legendFormat": "{{status}}", "instant": true }
      ],
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-RdYlGr" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] },
          "decimals": 0
        }
      }
    }
  ]
}
