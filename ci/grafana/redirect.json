{
  "uid": "redirect",
  "title": "redirect",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "current": { "selected": true, "text": "prod", "value": "prod2" },
        "options": [
          { "selected": true, "text": "prod", "value": "prod2" },
          { "selected": false, "text": "uat", "value": "uat" }
        ],
        "query": "prod : prod2, uat : uat",
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Users",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "alias(redirect-$env.db.users.all, 'all')" },
        { "refId": "B", "target": "alias(redirect-$env.db.users.active, 'active')" },
        { "refId": "C", "target": "alias(redirect-$env.db.users.online, 'online')" },
        { "refId": "D", "target": "alias(redirect-$env.db.users.subscribed, 'subscribed')" },
        { "refId": "E", "target": "alias(redirect-$env.db.users.dead, 'dead')" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Devices",
      "gridPos": { "x": 0, "y": 7, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "alias(redirect-$env.db.devices, 'total')" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "DNS",
      "gridPos": { "x": 12, "y": 7, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "alias(redirect-$env.domain.clean, 'clean')" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network (bytes)",
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "aliasByNode(redirect-$env.interface-eth0.if_octets.*, 3)" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Memory (bytes)",
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "aliasByNode(redirect-$env.memory.*, 2)" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU (%)",
      "gridPos": { "x": 0, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "aliasByNode(redirect-$env.cpu-0.cpu-system, 2)" },
        { "refId": "B", "target": "aliasByNode(redirect-$env.cpu-0.cpu-user, 2)" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" },
          "unit": "percent"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Disk (bytes)",
      "gridPos": { "x": 12, "y": 21, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "aliasByNode(redirect-$env.disk-xvda1.disk_octets.*, 2, 3)" },
        { "refId": "B", "target": "aliasByNode(redirect-$env.disk-xvda1.disk_io_time.io_time, 2, 3)" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Requests",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "aliasByNode(stats_counts.redirect-$env.*.*.*, 2, 3, 4)" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Cleaner",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 7 },
      "datasource": { "type": "graphite", "uid": "000000002" },
      "targets": [
        { "refId": "A", "target": "alias(stats.redirect-$env.cleaner.domain.delete, 'delete')" },
        { "refId": "B", "target": "alias(stats.redirect-$env.cleaner.domain.error, 'error')" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "lineWidth": 2, "fillOpacity": 5 },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ]
}
